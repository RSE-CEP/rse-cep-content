---
interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — RSE-CEP</title>
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        max-width: 52rem;
        margin: 0 auto;
        padding: 1rem;
        color: #1a1a1a;
      }
      nav {
        border-bottom: 1px solid #ddd;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
      }
      nav a {
        color: #0066cc;
        text-decoration: none;
        font-weight: 600;
      }
      nav a:hover { text-decoration: underline; }
      h1 { margin-bottom: 0.5rem; }
      h2 { margin-top: 1.5rem; margin-bottom: 0.5rem; }
      h3 { margin-top: 1rem; margin-bottom: 0.25rem; }
      p, ul, ol { margin-bottom: 0.75rem; }
      a { color: #0066cc; }
      table {
        border-collapse: collapse;
        width: 100%;
        margin-bottom: 1rem;
      }
      th, td {
        border: 1px solid #ddd;
        padding: 0.4rem 0.75rem;
        text-align: left;
      }
      th { background: #f5f5f5; width: 10rem; }
      .tag {
        display: inline-block;
        background: #e8f0fe;
        color: #1a56db;
        padding: 0.1rem 0.5rem;
        border-radius: 3px;
        font-size: 0.85rem;
        margin: 0.1rem;
      }
      .tag--domain {
        background: #fef3c7;
        color: #92400e;
      }
      .experimental-banner {
        background: #fef3c7;
        border: 2px solid #d97706;
        color: #92400e;
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-bottom: 1.5rem;
        font-weight: 600;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href={`${base}`}>RSE-CEP Patterns</a>
    </nav>
    <div class="experimental-banner">
      Experimental — This site and all pattern content are prototypes under active development. Content may be incomplete, inaccurate, or change without notice.
    </div>
    <slot />
  </body>
</html>
