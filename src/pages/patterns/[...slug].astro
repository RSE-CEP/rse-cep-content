---
import { getCollection, render } from 'astro:content';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import yaml from 'js-yaml';
import Base from '../../layouts/Base.astro';

import relatedPatternsData from '../../data/related-patterns.json';
import principleAlignmentsData from '../../data/principle-alignments.json';

const principlesRaw = readFileSync(resolve(process.cwd(), 'src/data/principles.yml'), 'utf-8');
const principlesDoc = yaml.load(principlesRaw);
const principlesMap = new Map((principlesDoc.principles || []).map((p) => [p.id, p]));

const RELATIONSHIP_LABELS = {
  'works-well-with': 'Works Well With',
  'alternative-approach': 'Alternative Approach',
  'typical-sequence-before': 'Typical Sequence: Before',
  'typical-sequence-after': 'Typical Sequence: After',
};

export async function getStaticPaths() {
  const patterns = await getCollection('patterns');
  return patterns.map((pattern) => ({
    params: { slug: pattern.id },
    props: { pattern },
  }));
}

const { pattern } = Astro.props;
const { Content } = await render(pattern);
const d = pattern.data;
const patternId = d.pattern_id;

const citationDate = d.last_updated.toISOString().slice(0, 10);
const citationYear = d.last_updated.getFullYear();

// Related patterns for this pattern
const relationships = relatedPatternsData[patternId] || [];
const groupedRelationships = {};
for (const rel of relationships) {
  const label = RELATIONSHIP_LABELS[rel.relationship] || rel.relationship;
  if (!groupedRelationships[label]) groupedRelationships[label] = [];
  groupedRelationships[label].push(rel);
}
const hasRelationships = relationships.length > 0;

// Build a map of pattern_id → slug for linking
const allPatterns = await getCollection('patterns');
const patternSlugMap = new Map(allPatterns.map((p) => [p.data.pattern_id, p.id]));
const patternTitleMap = new Map(allPatterns.map((p) => [p.data.pattern_id, p.data.title]));

// Principle alignments for this pattern
const alignments = principleAlignmentsData[patternId] || [];
const hasAlignments = alignments.length > 0;
---

<Base title={d.title}>
  <h1>{d.title}</h1>

  <table>
    <tbody>
      <tr><th>Pattern ID</th><td>{d.pattern_id}</td></tr>
      <tr><th>Pattern Type</th><td style="text-transform:capitalize;">{d.pattern_type}</td></tr>
      {d.alternative_names && d.alternative_names.length > 0 && (
        <tr><th>Also known as</th><td>{d.alternative_names.join(', ')}</td></tr>
      )}
      <tr><th>Author</th><td>{d.author}</td></tr>
      <tr><th>Last updated</th><td>{citationDate}</td></tr>
      {d.version && <tr><th>Version</th><td>{d.version}</td></tr>}
      <tr>
        <th>Keywords</th>
        <td>{d.keywords.map((kw: string) => <span class="tag">{kw}</span>)}</td>
      </tr>
      <tr>
        <th>HASS Domains</th>
        <td>{d.hass_domains.map((dom: string) => <span class="tag tag--domain">{dom}</span>)}</td>
      </tr>
      {d.source_type && <tr><th>Source type</th><td>{d.source_type}</td></tr>}
      {d.source_ref && <tr><th>Source ref</th><td>{d.source_ref}</td></tr>}
    </tbody>
  </table>

  <article>
    <Content />
  </article>

  {hasRelationships && (
    <section class="related-patterns">
      <h2>Related Patterns</h2>
      {Object.entries(groupedRelationships).map(([label, rels]) => (
        <div class="relationship-group">
          <h3>{label}</h3>
          <ul>
            {rels.map((rel) => {
              const slug = patternSlugMap.get(rel.related_id);
              const title = patternTitleMap.get(rel.related_id) || rel.related_id;
              return (
                <li>
                  {slug ? (
                    <a href={`${import.meta.env.BASE_URL}/patterns/${slug}/`}>
                      <strong>{rel.related_id}: {title}</strong>
                    </a>
                  ) : (
                    <strong>{rel.related_id}: {title}</strong>
                  )}
                  {rel.rationale && <span class="rationale"> — {rel.rationale}</span>}
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </section>
  )}

  {hasAlignments && (
    <section class="principle-alignments">
      <h2>Principle Alignments</h2>
      <ul>
        {alignments.map((a) => {
          const principle = principlesMap.get(a.principle_id);
          const name = principle ? principle.name : a.principle_id;
          const group = principle ? principle.group : '';
          return (
            <li>
              {group && <span class="principle-group">{group}</span>}
              <strong>{name}</strong>
              <span class="relevance"> — {a.relevance}</span>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <hr class="boilerplate-divider" />

  <aside class="site-boilerplate">
    <h2>Key References</h2>
    <ul>
      <li>Alexander, C. (1977). <em>A Pattern Language: Towns, Buildings, Construction</em>. Oxford University Press.</li>
      <li>Alexander, C. (1979). <em>The Timeless Way of Building</em>. Oxford University Press.</li>
      <li>Carroll, S. R., Garba, I., Figueroa-Rodríguez, O. L., Holbrook, J., Lovett, R., Materechera, S., Parsons, M., Raseroka, K., Rodriguez-Lonebear, D., Rowe, R., Sara, R., Walker, J. D., Anderson, J., &amp; Hudson, M. (2020). The CARE Principles for Indigenous Data Governance. <em>Data Science Journal</em>, <em>19</em>(1), 43. <a href="https://doi.org/10.5334/dsj-2020-043">https://doi.org/10.5334/dsj-2020-043</a></li>
      <li>Gamma, E., Helm, R., Johnson, R., &amp; Vlissides, J. (1994). <em>Design Patterns: Elements of Reusable Object-Oriented Software</em>. Addison-Wesley Professional.</li>
      <li>Goth, F., Alves, R., Braun, M., et al. (2024). Foundational Competencies and Responsibilities of a Research Software Engineer. <em>F1000Research</em>, <em>13</em>:1429. <a href="https://doi.org/10.12688/f1000research.157778.1">https://doi.org/10.12688/f1000research.157778.1</a></li>
    </ul>

    <h2>Citation</h2>
    <p>
      {d.author} ({citationYear}). {d.title}. CDL Recommended Patterns in RSE for HASS &amp; Indigenous Research, {d.pattern_id}.
    </p>

    <h2>License and Repository</h2>
    <p>
      This pattern is licensed under <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>.
      Source repository: <a href="https://github.com/rse-cep/content">rse-cep/content</a>.
    </p>

    <h2>Acknowledgments</h2>
    <p>
      This work is supported by the Australian Research Data Commons (ARDC) HASS and Indigenous Research Data Commons.
    </p>
  </aside>
</Base>

<style>
  .boilerplate-divider {
    margin-top: 3rem;
    border: none;
    border-top: 2px solid #ddd;
  }
  .site-boilerplate {
    margin-top: 2rem;
    padding: 1.5rem;
    background: #f8f9fa;
    border-radius: 6px;
    font-size: 0.9em;
    color: #555;
  }
  .site-boilerplate h2 {
    font-size: 1.1em;
    color: #333;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .site-boilerplate h2:first-child {
    margin-top: 0;
  }
  .site-boilerplate ul {
    padding-left: 1.5rem;
  }
  .site-boilerplate li {
    margin-bottom: 0.5rem;
  }
  .related-patterns,
  .principle-alignments {
    margin-top: 2rem;
    padding: 1.5rem;
    background: #f0f4ff;
    border-radius: 6px;
    border-left: 4px solid #4a6fa5;
  }
  .related-patterns h2,
  .principle-alignments h2 {
    margin-top: 0;
    color: #2c3e50;
    font-size: 1.3em;
  }
  .relationship-group h3 {
    font-size: 1em;
    color: #4a6fa5;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  .related-patterns ul,
  .principle-alignments ul {
    padding-left: 1.5rem;
  }
  .related-patterns li,
  .principle-alignments li {
    margin-bottom: 0.75rem;
  }
  .rationale,
  .relevance {
    color: #555;
  }
  .principle-group {
    display: inline-block;
    background: #4a6fa5;
    color: white;
    font-size: 0.75em;
    padding: 0.15em 0.5em;
    border-radius: 3px;
    margin-right: 0.5em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    vertical-align: middle;
  }
</style>
